{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./typescript/tsconfig.base.json",
  "include": ["*.d.ts", "eslint/", "prettier/"],
  "exclude": [
    "test/",
    // Git merge conflict files
    "**/*_BACKUP_*.*",
    "**/*_BASE_*.*",
    "**/*_LOCAL_*.*",
    "**/*_REMOTE_*.*"
  ],
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rewriteRelativeImportExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "outDir": "esm/",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "lib": ["esnext"],
    "skipLibCheck": true
  }
}
